# WordPress connection
WORDPRESS_URL=http://santron.local
WORDPRESS_USERNAME=admin
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# MCP Adapter endpoint (auto-derived from WORDPRESS_URL if not set)
# MCP_ENDPOINT=http://santron.local/wp-json/mcp/mcp-adapter-default-server

# Screenshot settings
SCREENSHOT_VIEWPORT_WIDTH=1920
SCREENSHOT_VIEWPORT_HEIGHT=1080
SCREENSHOT_TIMEOUT=15000

# Session settings
SESSION_TIMEOUT_MINUTES=30
